{
    "name": "karnull.github.io Dockerfile",

    "build": {
        "dockerfile": "${localWorkspaceFolder}/Dockerfile",
        "target": "dev_base"
    },

    "runArgs": [
        "--name=${localWorkspaceFolderBasename}-devcontainer",
        "-p", "8080:8080"
    ],

    "features": {
        "ghcr.io/devcontainers/features/node:1": { "version": "lts" }
    },

    "forwardPorts": [8080],
    "portsAttributes": {
        "8080": {
            "label": "Vite dev server",
            "onAutoForward": "notify"
        }
    },

    "postCreateCommand": "npm install",
    "containerEnv": {
        "TERM": "${localEnv:TERM}"
    },

    "initializeCommand":
        "if [ ! -f ${localWorkspaceFolder}/.devcontainer/.bash_history ]; then echo 'Bash History file does not exist. Creating it...'; touch ${localWorkspaceFolder}/.devcontainer/.bash_history; fi;",
    "mounts": [
        "type=bind,source=/etc/localtime,target=/etc/localtime,readonly",
        "type=bind,source=/etc/timezone,target=/etc/timezone,readonly",
        "source=${localWorkspaceFolder}/.devcontainer/.bash_history,target=/home/vscode/.bash_history,type=bind,consistency=cached"
    ],
}
